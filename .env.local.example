# Supabase — Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...

# Public site URL (used for metadataBase / OG URLs)
# - Vercel: https://truegrynd.vercel.app
# - Custom: https://truegrynd.app
NEXT_PUBLIC_SITE_URL=https://truegrynd.vercel.app

# Server-side only — NEVER expose to the client
# Used for admin operations (seeding, RLS bypass)
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# E2E auth test user (Supabase auth.users)
E2E_TEST_EMAIL=test@example.com
E2E_TEST_PASSWORD=testpassword123

# --- Admin AI triage (Supabase Edge Function, not Vercel) ---
